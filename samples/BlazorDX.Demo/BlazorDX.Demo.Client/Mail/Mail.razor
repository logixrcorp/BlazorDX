@page "/mail"
@layout MailLayout
@rendermode InteractiveWebAssembly
@using System.Text.RegularExpressions
@using BlazorDX.Components
@using BlazorDX.Security
@inject MailStore Store

<PageTitle>Mailbox — @FolderLabel</PageTitle>

<div class="mail-app">
    <aside class="mail-folders" aria-label="Folders">
        <button type="button" class="mail-compose" @onclick="OpenCompose">✎ Compose</button>
        @foreach (MailFolderInfo f in Store.Folders)
        {
            int unread = Store.UnreadCount(f.Kind);
            <button type="button"
                    class="mail-folder @(f.Kind == folder ? "mail-folder-on" : "")"
                    @onclick="() => SelectFolder(f.Kind)">
                <span class="mail-folder-ico">@f.Icon</span>
                <span class="mail-folder-name">@f.Label</span>
                @if (unread > 0)
                {
                    <span class="mail-folder-badge">@unread</span>
                }
            </button>
        }
    </aside>

    <section class="mail-list" aria-label="Messages">
        <div class="mail-search">
            <input type="search" placeholder="Search mail" aria-label="Search mail"
                   @bind="search" @bind:event="oninput" />
        </div>
        @if (Messages.Count == 0)
        {
            <p class="mail-empty">No messages.</p>
        }
        else
        {
            @foreach (MailMessage m in Messages)
            {
                <button type="button"
                        class="mail-item @(m.Id == selected?.Id ? "mail-item-on" : "") @(m.Unread ? "mail-item-unread" : "")"
                        @onclick="() => Open(m)">
                    <span class="mail-avatar" aria-hidden="true">@m.Initials</span>
                    <span class="mail-item-main">
                        <span class="mail-item-top">
                            <span class="mail-item-from">@(folder == MailFolderKind.Sent ? $"To: {m.To}" : m.From)</span>
                            <span class="mail-item-time">@m.TimeLabel</span>
                        </span>
                        <span class="mail-item-subject">@m.Subject</span>
                        <span class="mail-item-preview">@m.Preview</span>
                    </span>
                    <span class="mail-star @(m.Starred ? "mail-star-on" : "")"
                          role="button" aria-label="Toggle star"
                          @onclick="() => Store.ToggleStar(m)" @onclick:stopPropagation="true">★</span>
                </button>
            }
        }
    </section>

    <section class="mail-read" aria-label="Reading pane">
        @if (selected is null)
        {
            <div class="mail-read-empty">
                <span class="mail-read-empty-ico">✉</span>
                <p>Select a message to read it.</p>
            </div>
        }
        else
        {
            <div class="mail-read-head">
                <h1>@selected.Subject</h1>
                <div class="mail-read-actions">
                    <button type="button" class="mail-btn" @onclick="() => Store.ToggleStar(selected)">
                        @(selected.Starred ? "★ Starred" : "☆ Star")
                    </button>
                    <button type="button" class="mail-btn" @onclick="Archive">🗄 Archive</button>
                    <button type="button" class="mail-btn" @onclick="Delete">🗑 Delete</button>
                    <button type="button" class="mail-btn mail-btn-primary" @onclick="Reply">↩ Reply</button>
                </div>
            </div>
            <div class="mail-read-meta">
                <span class="mail-avatar mail-avatar-lg" aria-hidden="true">@selected.Initials</span>
                <div>
                    <div class="mail-read-from">@selected.From <span class="mail-read-email">&lt;@selected.FromEmail&gt;</span></div>
                    <div class="mail-read-to">to @selected.To · @selected.Received.ToString("dddd, MMM d, yyyy HH:mm")</div>
                </div>
                @if (selected.Labels.Count > 0)
                {
                    <div class="mail-labels">
                        @foreach (string label in selected.Labels)
                        {
                            <span class="mail-label">@label</span>
                        }
                    </div>
                }
            </div>
            <article class="mail-body">@sanitizer.Sanitize(selected.BodyHtml)</article>
        }
    </section>
</div>

<DxSheet @bind-Open="composeOpen" Side="right" AriaLabel="Compose message">
    <div class="mail-compose-form">
        <h2>New message</h2>
        <label class="mail-field">
            <span>To</span>
            <input type="text" @bind="draftTo" placeholder="name@example.com" />
        </label>
        <label class="mail-field">
            <span>Subject</span>
            <input type="text" @bind="draftSubject" placeholder="Subject" />
        </label>
        <span class="mail-field-label">Message</span>
        <DxRichTextEditor @bind-Value="draftBody" Sanitizer="sanitizer" AriaLabel="Message body" />
        <div class="mail-compose-actions">
            <button type="button" class="mail-btn" @onclick="() => composeOpen = false">Cancel</button>
            <button type="button" class="mail-btn mail-btn-primary" @onclick="SendDraft">Send</button>
        </div>
    </div>
</DxSheet>

@code {
    private MailFolderKind folder = MailFolderKind.Inbox;
    private MailMessage? selected;
    private string search = string.Empty;

    private bool composeOpen;
    private string draftTo = string.Empty;
    private string draftSubject = string.Empty;
    private string? draftBody = string.Empty;

    private string FolderLabel => Store.Folders.First(f => f.Kind == folder).Label;

    private IReadOnlyList<MailMessage> Messages
    {
        get
        {
            IReadOnlyList<MailMessage> all = Store.InFolder(folder);
            if (string.IsNullOrWhiteSpace(search))
            {
                return all;
            }

            string q = search.Trim();
            return all.Where(m =>
                m.Subject.Contains(q, StringComparison.OrdinalIgnoreCase)
                || m.From.Contains(q, StringComparison.OrdinalIgnoreCase)
                || m.Preview.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private void SelectFolder(MailFolderKind kind)
    {
        folder = kind;
        selected = null;
        search = string.Empty;
    }

    private void Open(MailMessage m)
    {
        selected = m;
        Store.MarkRead(m);
    }

    private void Archive()
    {
        if (selected is not null)
        {
            Store.Move(selected, MailFolderKind.Archive);
            selected = null;
        }
    }

    private void Delete()
    {
        if (selected is not null)
        {
            Store.Move(selected, MailFolderKind.Trash);
            selected = null;
        }
    }

    private void Reply()
    {
        if (selected is null)
        {
            return;
        }

        draftTo = selected.FromEmail;
        draftSubject = selected.Subject.StartsWith("Re:", StringComparison.OrdinalIgnoreCase)
            ? selected.Subject
            : $"Re: {selected.Subject}";
        draftBody = $"<p></p><blockquote>{selected.BodyHtml}</blockquote>";
        composeOpen = true;
    }

    private void OpenCompose()
    {
        draftTo = string.Empty;
        draftSubject = string.Empty;
        draftBody = "<p></p>";
        composeOpen = true;
    }

    private void SendDraft()
    {
        MailMessage sent = Store.Send(draftTo, draftSubject, draftBody ?? string.Empty);
        composeOpen = false;
        folder = MailFolderKind.Sent;
        search = string.Empty;
        selected = sent;
    }

    // Demo-grade allow-list sanitizer (same policy as the Rich Text demo). BlazorDX ships no HTML
    // parser, so the app supplies the policy; every message body is rendered through it.
    private readonly HtmlSanitizer sanitizer = new(Clean);

    private static readonly HashSet<string> Allowed = new(StringComparer.OrdinalIgnoreCase)
    {
        "b", "strong", "i", "em", "u", "ins", "s", "strike", "del", "h2", "h3",
        "ul", "ol", "li", "p", "br", "a", "div", "span", "blockquote", "code",
    };

    private static string Clean(string input)
    {
        string html = Regex.Replace(input, "(?is)<(script|style)\\b.*?</\\1>", string.Empty);
        html = Regex.Replace(html, "(?i)\\son\\w+\\s*=\\s*\"[^\"]*\"", string.Empty);
        html = Regex.Replace(html, "(?i)\\son\\w+\\s*=\\s*'[^']*'", string.Empty);
        html = Regex.Replace(html, "(?i)(href|src)\\s*=\\s*([\"'])\\s*javascript:[^\"']*\\2", "$1=$2#$2");
        html = Regex.Replace(html, "(?i)</?([a-z0-9]+)[^>]*>",
            m => Allowed.Contains(m.Groups[1].Value) ? m.Value : string.Empty);
        return html;
    }
}
