@* A two-column "classic meets modern" magazine spread: an elevated, drop-shadowed photo
   collaged against body copy, with a small labeled spec card overlapping its corner — the
   fashion-editorial "swatch card" device, adapted here to show a real technical fact instead
   of a color chip. Alternates media/text sides via Reverse for rhythm against the full-bleed
   EditorialFigure breaks elsewhere in a piece. Stays on dx-theme.css tokens throughout. *@

<section class="dx-editorial-spread @(Reverse ? "dx-editorial-spread--reverse" : null)">
    <div class="dx-editorial-spread-media">
        <div class="dx-editorial-spread-photo">
            <img src="@ImageSrc" alt="@ImageAlt" loading="lazy" />
        </div>
        @if (!string.IsNullOrEmpty(SpecLabel))
        {
            <div class="dx-editorial-spread-spec">
                <span class="dx-editorial-spread-spec-label">@SpecLabel</span>
                <span class="dx-editorial-spread-spec-value">@SpecValue</span>
                @if (!string.IsNullOrEmpty(SpecCaption))
                {
                    <span class="dx-editorial-spread-spec-caption">@SpecCaption</span>
                }
            </div>
        }
    </div>
    <div class="dx-editorial-spread-text">
        @if (!string.IsNullOrEmpty(Kicker))
        {
            <span class="dx-editorial-spread-kicker">@Kicker</span>
        }
        <h2 class="dx-editorial-spread-title">@Title</h2>
        <div class="dx-editorial-spread-body">@ChildContent</div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string ImageSrc { get; set; } = "";

    [Parameter, EditorRequired] public string ImageAlt { get; set; } = "";

    /// <summary>A short serif-italic label above the title — the "classic" counterpoint to the bold sans title.</summary>
    [Parameter] public string? Kicker { get; set; }

    [Parameter, EditorRequired] public string Title { get; set; } = "";

    /// <summary>Overlaps the photo's corner. Use a real fact, not decoration — e.g. a cipher suite or a test name.</summary>
    [Parameter] public string? SpecLabel { get; set; }

    [Parameter] public string? SpecValue { get; set; }

    [Parameter] public string? SpecCaption { get; set; }

    /// <summary>Puts the photo on the right instead of the left, for rhythm across a piece with more than one spread.</summary>
    [Parameter] public bool Reverse { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
