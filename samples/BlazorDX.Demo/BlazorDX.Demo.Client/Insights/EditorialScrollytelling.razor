@* The scroll-driven data-flow section. The reveal itself is pure CSS transitions
   (dx-editorial.css .is-visible), toggled by a co-located IntersectionObserver script — never a
   scroll-position listener, so there's nothing running per scroll pixel. Self-contained: no
   C#/JS call is needed, the module wires itself on load (see EditorialScrollytelling.razor.js). *@

<script type="module" src="@Assets["Insights/EditorialScrollytelling.razor.js"]"></script>

<section class="dx-editorial-scrolly">
    @if (!string.IsNullOrEmpty(Intro))
    {
        <p class="dx-editorial-scrolly-intro">@Intro</p>
    }
    @ChildContent
</section>

@code {
    [Parameter] public string? Intro { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
