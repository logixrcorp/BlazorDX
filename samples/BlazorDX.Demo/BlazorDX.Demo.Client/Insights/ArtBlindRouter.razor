@* Hand-authored SVG: ciphertext passes straight through the router untouched. The router is
   drawn as an empty dashed frame — nothing to fill in, because it never holds a key. Colored
   entirely with dx-theme.css tokens. *@

<svg viewBox="0 0 1200 420" width="100%" role="img"
     aria-label="A filled circle on the left, representing the provider that encrypts a message, connects along a line through an empty dashed square labeled router, to a filled circle on the right representing the browser. Small hollow squares along the line represent encrypted packets that stay closed the entire way."
     xmlns="http://www.w3.org/2000/svg">
    <line x1="140" y1="210" x2="1060" y2="210" stroke="var(--dx-border, #e2e8f0)" stroke-width="2" />

    <circle cx="120" cy="210" r="26" fill="var(--dx-accent, #2563eb)" />
    <text x="120" y="266" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14"
          font-weight="600" letter-spacing="0.06em" fill="var(--dx-text-muted, #64748b)">PROVIDER</text>

    <rect x="256" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />
    <rect x="336" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />
    <rect x="416" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />

    <rect x="520" y="130" width="160" height="160" rx="18" fill="var(--dx-surface, #ffffff)"
          stroke="var(--dx-text-muted, #64748b)" stroke-width="2" stroke-dasharray="6 6" />
    <text x="600" y="118" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="15"
          font-weight="700" letter-spacing="0.1em" fill="var(--dx-text-muted, #64748b)">ROUTER</text>

    <rect x="758" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />
    <rect x="838" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />
    <rect x="918" y="195" width="26" height="26" rx="4" fill="none" stroke="var(--dx-text-muted, #64748b)" stroke-width="2" />

    <circle cx="1080" cy="210" r="26" fill="var(--dx-accent, #2563eb)" />
    <text x="1080" y="266" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-size="14"
          font-weight="600" letter-spacing="0.06em" fill="var(--dx-text-muted, #64748b)">BROWSER</text>
</svg>
