@* A "data-as-art" moment for the impermanence stage: a grid of dots that fade, shrink, and blur
   away once their parent .dx-editorial-scrolly-stage gains .is-visible (see dx-editorial.css) —
   a CSS-only study, no canvas/WebGL, no JS beyond the shared reveal observer. *@

<div class="dx-editorial-dissipation" role="img" aria-label="@AriaLabel">
    @for (int i = 0; i < DotCount; i++)
    {
        int captured = i;
        <span class="dissolve" style="--i:@captured"></span>
    }
</div>

@code {
    [Parameter] public int DotCount { get; set; } = 24;

    [Parameter] public string AriaLabel { get; set; } =
        "An illustration of ephemeral content fading away once its session ends.";
}
