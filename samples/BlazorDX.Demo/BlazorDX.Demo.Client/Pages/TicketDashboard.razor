@page "/app"
@layout TicketDeskLayout
@rendermode InteractiveWebAssembly
@inject TicketStore Store

<PageTitle>Service Desk — Dashboard</PageTitle>

<div class="td-head">
    <div>
        <h1>Service Desk</h1>
        <p>ITIL incidents, requests, problems &amp; changes — priority from the Impact × Urgency matrix, with live SLA tracking.</p>
    </div>
    <a class="td-btn td-btn-primary" href="/app/new">＋ New record</a>
</div>

<div class="td-stats">
    <div class="td-stat"><div class="td-stat-n">@Store.OpenCount</div><div class="td-stat-l">Open</div></div>
    <div class="td-stat"><div class="td-stat-n" style="color:#b91c1c">@Store.SlaBreaches</div><div class="td-stat-l">SLA breached</div></div>
    <div class="td-stat"><div class="td-stat-n" style="color:#c2410c">@Store.AtRisk</div><div class="td-stat-l">SLA at risk</div></div>
    <div class="td-stat"><div class="td-stat-n" style="color:#b91c1c">@Store.Count(Priority.Critical)</div><div class="td-stat-l">P1 critical open</div></div>
    <div class="td-stat"><div class="td-stat-n" style="color:#15803d">@Store.SlaCompliance.ToString("0")%</div><div class="td-stat-l">SLA compliance</div></div>
</div>

<div class="td-grid2">
    <div class="td-card">
        <h2>Open by priority</h2>
        <DxBarChart Bars="priorityBars" Width="420" Height="220" />
    </div>
    <div class="td-card">
        <h2>Records by practice</h2>
        <div style="display:flex; gap:24px; align-items:center; flex-wrap:wrap">
            <DxPieChart Slices="typeBars" Donut="true" />
            <DxRadialGauge Value="@Store.SlaCompliance" Label="SLA %" Size="120" Color="#16a34a" Format="0" />
        </div>
    </div>
</div>

<div class="td-card" style="margin-top:16px">
    <h2>SLA breached &amp; at risk</h2>
    @{
        var attention = Store.All().Where(r => !r.IsResolved && (r.SlaBreached || r.SlaConsumedPercent >= 70))
            .OrderByDescending(r => r.SlaBreached).ThenByDescending(r => r.SlaConsumedPercent).Take(8).ToList();
    }
    @if (attention.Count == 0)
    {
        <p class="dx-demo-meta">Everything is within SLA. 🎉</p>
    }
    <div class="td-list">
        @foreach (Ticket t in attention)
        {
            <a class="td-row" href="@($"/app/record/{t.Id}")">
                <span class="td-row-id">@t.Number</span>
                <span class="td-row-title">@t.ShortDescription</span>
                <span class="td-row-meta">
                    <span class="@ItilUi.PriorityClass(t.Priority)">@ItilUi.PriorityLabel(t.Priority)</span>
                    <span class="@ItilUi.SlaClass(t)">@ItilUi.SlaLabel(t)</span>
                </span>
            </a>
        }
    </div>
</div>

@code {
    private IReadOnlyList<ChartBar> priorityBars = [];
    private IReadOnlyList<ChartBar> typeBars = [];

    protected override void OnInitialized()
    {
        priorityBars = ItilUi.Priorities.Select(p => new ChartBar(ItilUi.PriorityLabel(p), Store.Count(p))).ToList();
        typeBars = ItilUi.Types.Select(t => new ChartBar(ItilUi.TypeLabel(t), Store.OpenOfType(t))).ToList();
    }
}
