@page "/grid"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components
@using BlazorDX.Compute
@using BlazorDX.Primitives.Grid
@inject IGridCompute Compute

<PageTitle>DataGrid</PageTitle>

<h1>BlazorDX DataGrid</h1>

<p class="dx-demo-meta">
    <strong>@People.Count.ToString("N0")</strong> rows, virtualized to the viewport.
    Compute backend: <strong>@Compute.Backend</strong>.
    Click a column header to sort — numeric columns run through the Rust/wasm kernel.
</p>

<div style="display:flex; gap:8px; margin-bottom:10px; align-items:center">
    <button class="dx-demo-button" @onclick="() => groupBy = 2">Group by City</button>
    <button class="dx-demo-button" style="background:#64748b" @onclick="() => groupBy = -1">No grouping</button>
    <span class="dx-demo-meta" style="margin:0">Selected: <strong>@selectedCount</strong></span>
    <span class="dx-demo-meta" style="margin:0">Last edit: <strong>@lastEdit</strong></span>
</div>
<p class="dx-demo-meta">Double-click a Name, City, Score, or Visits cell to edit it in place (Enter commits, Esc cancels). Drag a column's right edge to resize it. Click into the grid and use the arrow keys, Home/End, and Ctrl+Home/End to move the active cell (it scrolls into view across all 100k rows).</p>

<div style="display:flex; gap:8px; margin-bottom:10px; align-items:center; flex-wrap:wrap">
    <button class="dx-demo-button" @onclick="SaveLayout">Save layout</button>
    <button class="dx-demo-button" style="background:#64748b" @onclick="RestoreLayout" disabled="@(savedLayout is null)">Restore layout</button>
    <button class="dx-demo-button" style="background:#94a3b8" @onclick="ClearLayout" disabled="@(savedLayout is null)">Clear saved</button>
    <span class="dx-demo-meta" style="margin:0">@layoutStatus</span>
</div>
<p class="dx-demo-meta">Reorder, resize, hide, sort, or filter columns above, then <strong>Save layout</strong> — the JSON snapshot below is what a host would persist to localStorage or a user profile. <strong>Restore</strong> re-applies it; stale entries that no longer fit the columns are ignored.</p>
@if (savedLayout is not null)
{
    <pre class="dx-demo-meta" style="white-space:pre-wrap; word-break:break-all; background:var(--dx-surface-2, #f1f5f9); padding:8px 10px; border-radius:6px; max-width:100%"><code>@savedLayout</code></pre>
}

<DxDataGrid @ref="grid"
            TRow="PersonRow"
            OnStateChanged="OnLayoutChanged"
            Items="People"
            Accessor="accessor"
            Aggregations="aggregations"
            GroupByColumn="groupBy"
            Selectable="true"
            Filterable="true"
            Editable="true"
            PinnedColumns="2"
            ShowExport="true"
            ExportFileName="people.csv"
            ShowExcelExport="true"
            ExcelFileName="people.xlsx"
            ShowPdfExport="true"
            PdfFileName="people.pdf"
            ShowClipboard="true"
            ShowColumnChooser="true"
            ShowFilterMenu="true"
            KeyboardNavigation="true"
            SelectionChanged="OnSelectionChanged"
            RowEdited="OnRowEdited"
            RowHeight="32"
            ViewportHeight="520" />

<h2 style="margin-top:32px">Master / detail</h2>
<p class="dx-demo-meta">Click the ▸ twisty on a row to expand an inline detail panel.</p>

<DxDataGrid TRow="PersonRow"
            Items="detailPeople"
            Accessor="accessor"
            RowHeight="32"
            ViewportHeight="320">
    <DetailTemplate Context="p">
        <div style="display:flex; gap:24px; flex-wrap:wrap">
            <div><strong>@p.Name</strong></div>
            <div>City: <strong>@p.City</strong></div>
            <div>Score: <strong>@p.Score.ToString("F2")</strong></div>
            <div>Visits: <strong>@p.Visits</strong></div>
        </div>
    </DetailTemplate>
</DxDataGrid>

@code {
    // The accessor type is generated by BlazorDX.SourceGen from [GridRow] on PersonRow.
    private readonly PersonRowGridAccessor accessor = new();

    private DxDataGrid<PersonRow>? grid;
    private string? savedLayout;
    private string layoutStatus = "No layout saved yet.";

    // Fired by the grid on every reorder / resize / hide / sort / filter. A real host would
    // debounce this straight into localStorage; here we just nudge the user to Save.
    private void OnLayoutChanged(GridState state)
    {
        if (savedLayout is not null && state.ToJson() != savedLayout)
        {
            layoutStatus = "Layout changed — Save to persist.";
        }
    }

    private void SaveLayout()
    {
        savedLayout = grid?.CaptureState().ToJson();
        layoutStatus = "Layout saved.";
    }

    private async Task RestoreLayout()
    {
        if (grid is not null && savedLayout is not null)
        {
            await grid.ApplyStateAsync(GridState.FromJson(savedLayout));
            layoutStatus = "Layout restored.";
        }
    }

    private void ClearLayout()
    {
        savedLayout = null;
        layoutStatus = "Saved layout cleared.";
    }

    private IReadOnlyList<PersonRow> People { get; } = SampleData.People(100_000);

    private IReadOnlyList<PersonRow> detailPeople => People.Take(8).ToList();

    private int groupBy = -1;
    private int selectedCount;

    private void OnSelectionChanged(IReadOnlyList<PersonRow> selected) => selectedCount = selected.Count;

    private string lastEdit = "(none)";

    private void OnRowEdited(PersonRow row) => lastEdit = $"{row.Name} / {row.City} / {row.Score}";

    // Footer aggregates, computed by the Rust kernel: Score column (3) mean, Visits (4) sum.
    private readonly Dictionary<int, GridAggregateKind> aggregations = new()
    {
        [3] = GridAggregateKind.Mean,
        [4] = GridAggregateKind.Sum,
    };
}
