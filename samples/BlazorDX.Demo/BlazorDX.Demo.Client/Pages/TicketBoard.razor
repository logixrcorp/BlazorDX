@page "/app/board"
@layout TicketDeskLayout
@rendermode InteractiveWebAssembly
@inject TicketStore Store
@inject ToastService Toasts

<PageTitle>TicketDesk — Board</PageTitle>

<div class="td-head">
    <div>
        <h1>Board</h1>
        <p>Drag a ticket between columns to change its status — native HTML5 drag, no JavaScript. Or focus a card and use <strong>Ctrl + ←/→</strong>.</p>
    </div>
    <a class="td-btn td-btn-primary" href="/app/new">＋ New ticket</a>
</div>

<DxKanban Columns="columns" OnChange="OnBoardChange" />

<DxToastHost />

@code {
    private readonly List<KanbanColumn> columns = new();
    private readonly Dictionary<KanbanCard, int> cardToId = new();

    // The board shows the four active statuses; Closed tickets are archived and omitted.
    private static readonly TicketStatus[] BoardStatuses =
        { TicketStatus.Open, TicketStatus.InProgress, TicketStatus.Blocked, TicketStatus.Resolved };

    protected override void OnInitialized()
    {
        foreach (TicketStatus status in BoardStatuses)
        {
            KanbanColumn col = new(TicketUi.Label(status));
            foreach (Ticket t in Store.All().Where(t => t.Status == status).OrderByDescending(t => t.Priority))
            {
                KanbanCard card = new($"#{t.Id} · {t.Title}", t.Priority.ToString());
                col.Cards.Add(card);
                cardToId[card] = t.Id;
            }

            columns.Add(col);
        }
    }

    // DxKanban mutates the column/card lists in place and raises OnChange. We reconcile each
    // card's current column back to its ticket's status via the reference-identity map.
    private void OnBoardChange()
    {
        for (int i = 0; i < columns.Count; i++)
        {
            foreach (KanbanCard card in columns[i].Cards)
            {
                if (cardToId.TryGetValue(card, out int id))
                {
                    Store.SetStatus(id, BoardStatuses[i]);
                }
            }
        }

        Toasts.Show("Board updated — ticket status saved.", "success");
    }
}
