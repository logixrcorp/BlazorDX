@page "/charts"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components

<PageTitle>Chart</PageTitle>

<h1>BlazorDX Line Chart</h1>

<p class="dx-demo-meta">
    A @points.Length.ToString("N0")-point series drawn as a single SVG polyline,
    LTTB-downsampled by the Rust/wasm kernel to keep the shape with only a few
    hundred points. The caption shows the active compute backend.
</p>

<DxLineChart Points="lineData" Threshold="400" Width="720" Height="240" />

<h2 style="margin-top:32px">Area chart</h2>
<p class="dx-demo-meta">A filled series, also Rust-downsampled.</p>
<DxAreaChart Points="areaData" Threshold="300" Width="720" Height="200" />

<h2 style="margin-top:32px">Bar chart</h2>
<DxBarChart Points="bars" Width="720" Height="240" />

<h2 style="margin-top:32px">Histogram (Rust binning)</h2>
<p class="dx-demo-meta">
    @sample.Length.ToString("N0") normally-distributed samples binned into 16 buckets
    by the compute backend — the caption names it.
</p>
<DxHistogram Values="sample" Bins="16" Width="720" Height="220" />

<h2 style="margin-top:32px">Pie &amp; donut</h2>
<div style="display:flex; gap:32px; flex-wrap:wrap">
    <DxPieChart Points="slices" />
    <DxPieChart Points="slices" Donut="true" />
</div>

<h2 style="margin-top:32px">Sparklines</h2>
<table style="border-collapse:collapse">
    <tr>
        <td style="padding:6px 14px">Revenue</td>
        <td style="padding:6px 14px"><DxSparkline Points="spark" /></td>
        <td style="padding:6px 14px"><DxSparkline Points="spark" Variant="bar" /></td>
    </tr>
</table>

<h2 style="margin-top:32px">Scatter</h2>
<DxScatterChart Points="scatter" Width="720" Height="260" />

<h2 style="margin-top:32px">Stacked &amp; grouped bar</h2>
<div style="display:flex; gap:32px; flex-wrap:wrap">
    <div>
        <p class="dx-demo-meta">Stacked</p>
        <DxStackedBarChart Categories="quarters" Points="stackedPoints" Width="340" Height="240" />
    </div>
    <div>
        <p class="dx-demo-meta">Grouped</p>
        <DxStackedBarChart Categories="quarters" Points="stackedPoints" Stacked="false" Width="340" Height="240" />
    </div>
</div>

<h2 style="margin-top:32px">Gauges</h2>
<div style="display:flex; gap:40px; flex-wrap:wrap; align-items:center">
    <DxRadialGauge Value="72" Label="CPU %" />
    <DxRadialGauge Value="46" Max="60" Label="FPS" Color="#16a34a" Format="0" />
    <div style="display:flex; flex-direction:column; gap:14px">
        <DxLinearGauge Value="72" AriaLabel="Disk" Zones="zones" />
        <DxLinearGauge Value="28" AriaLabel="Memory" Zones="zones" />
        <DxLinearGauge Value="95" AriaLabel="Heat" Zones="zones" />
    </div>
</div>

<h2 style="margin-top:32px">Radar</h2>
<DxRadarChart Axes="radarAxes" Points="radarPoints" Width="340" Height="340" />

<h2 style="margin-top:32px">Funnel</h2>
<DxFunnelChart Points="funnelStages" Width="380" Height="240" />

<h2 style="margin-top:32px">Candlestick</h2>
<DxCandlestickChart Points="candles" Width="640" Height="260" />

@code {
    private readonly double[] points = new double[6000];
    private IReadOnlyList<ChartPoint> lineData = [];
    private IReadOnlyList<ChartPoint> areaData = [];
    private double[] sample = [];

    private readonly IReadOnlyList<ChartPoint> bars =
    [
        new(Category: "Mon", Y: 18),
        new(Category: "Tue", Y: 32),
        new(Category: "Wed", Y: 27),
        new(Category: "Thu", Y: 41),
        new(Category: "Fri", Y: 36),
        new(Category: "Sat", Y: 12),
        new(Category: "Sun", Y: 9),
    ];

    private readonly IReadOnlyList<ChartPoint> spark =
    [
        new(Y: 4), new(Y: 7), new(Y: 5), new(Y: 9), new(Y: 6), new(Y: 11),
        new(Y: 8), new(Y: 13), new(Y: 10), new(Y: 15), new(Y: 12), new(Y: 17),
    ];

    private readonly IReadOnlyList<ChartPoint> scatter = BuildScatter();

    private static IReadOnlyList<ChartPoint> BuildScatter()
    {
        Random random = new(20260617);
        List<ChartPoint> pts = new(120);
        for (int i = 0; i < 120; i++)
        {
            double x = random.NextDouble() * 100;
            double y = (x * 0.6) + ((random.NextDouble() - 0.5) * 40);   // correlated with noise
            pts.Add(new ChartPoint(x, y));
        }

        return pts;
    }

    private readonly IReadOnlyList<string> quarters = ["Q1", "Q2", "Q3", "Q4"];

    // Flattened: one ChartPoint per (series, category) pair, tagged via Series + Category.
    private readonly IReadOnlyList<ChartPoint> stackedPoints =
    [
        new(Category: "Q1", Y: 18, Series: "Direct"), new(Category: "Q2", Y: 24, Series: "Direct"),
        new(Category: "Q3", Y: 30, Series: "Direct"), new(Category: "Q4", Y: 28, Series: "Direct"),
        new(Category: "Q1", Y: 12, Series: "Search"), new(Category: "Q2", Y: 16, Series: "Search"),
        new(Category: "Q3", Y: 14, Series: "Search"), new(Category: "Q4", Y: 22, Series: "Search"),
        new(Category: "Q1", Y: 8, Series: "Social"), new(Category: "Q2", Y: 6, Series: "Social"),
        new(Category: "Q3", Y: 11, Series: "Social"), new(Category: "Q4", Y: 9, Series: "Social"),
    ];

    private readonly IReadOnlyList<GaugeZone> zones =
    [
        new GaugeZone(50, "#16a34a"),
        new GaugeZone(80, "#d97706"),
        new GaugeZone(100, "#dc2626"),
    ];

    private readonly IReadOnlyList<string> radarAxes = ["Speed", "Power", "Range", "Agility", "Defense"];

    private readonly IReadOnlyList<ChartPoint> radarPoints =
    [
        new(Category: "Speed", Y: 80, Series: "Model A"), new(Category: "Power", Y: 55, Series: "Model A"),
        new(Category: "Range", Y: 70, Series: "Model A"), new(Category: "Agility", Y: 60, Series: "Model A"),
        new(Category: "Defense", Y: 90, Series: "Model A"),
        new(Category: "Speed", Y: 60, Series: "Model B"), new(Category: "Power", Y: 85, Series: "Model B"),
        new(Category: "Range", Y: 50, Series: "Model B"), new(Category: "Agility", Y: 75, Series: "Model B"),
        new(Category: "Defense", Y: 65, Series: "Model B"),
    ];

    private readonly IReadOnlyList<ChartPoint> funnelStages =
    [
        new(Category: "Visited", Y: 12000),
        new(Category: "Signed up", Y: 4800),
        new(Category: "Activated", Y: 2100),
        new(Category: "Purchased", Y: 720),
    ];

    private readonly IReadOnlyList<ChartPoint> candles =
    [
        new(Category: "Mon", Y: 100, Y2: 112, Y3: 96, Y4: 108),
        new(Category: "Tue", Y: 108, Y2: 114, Y3: 103, Y4: 105),
        new(Category: "Wed", Y: 105, Y2: 118, Y3: 104, Y4: 116),
        new(Category: "Thu", Y: 116, Y2: 120, Y3: 110, Y4: 112),
        new(Category: "Fri", Y: 112, Y2: 122, Y3: 108, Y4: 121),
    ];

    private readonly IReadOnlyList<ChartPoint> slices =
    [
        new(Category: "Direct", Y: 42),
        new(Category: "Search", Y: 28),
        new(Category: "Social", Y: 18),
        new(Category: "Email", Y: 12),
    ];

    protected override void OnInitialized()
    {
        // A noisy multi-frequency wave: lots of detail LTTB must preserve.
        Random random = new(20260617);
        ChartPoint[] line = new ChartPoint[points.Length];
        for (int i = 0; i < points.Length; i++)
        {
            double wave = (Math.Sin(i / 120.0) * 80) + (Math.Sin(i / 17.0) * 18);
            double y = wave + ((random.NextDouble() - 0.5) * 24);
            line[i] = new ChartPoint(X: i, Y: y);
        }

        lineData = line;

        // Area: a smoother positive series.
        ChartPoint[] area = new ChartPoint[1500];
        for (int i = 0; i < area.Length; i++)
        {
            area[i] = new ChartPoint(Y: 50 + (Math.Sin(i / 90.0) * 30) + (Math.Sin(i / 23.0) * 10));
        }

        areaData = area;

        // Histogram: 20k normal-ish samples (sum of uniforms → bell curve).
        sample = new double[20000];
        for (int i = 0; i < sample.Length; i++)
        {
            double s = 0;
            for (int k = 0; k < 6; k++)
            {
                s += random.NextDouble();
            }

            sample[i] = s / 6 * 100;   // centered near 50
        }
    }
}
