@page "/charts"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components

<PageTitle>Chart</PageTitle>

<h1>BlazorDX Line Chart</h1>

<p class="dx-demo-meta">
    A @points.Length.ToString("N0")-point series drawn as a single SVG polyline,
    LTTB-downsampled by the Rust/wasm kernel to keep the shape with only a few
    hundred points. The caption shows the active compute backend.
</p>

<DxLineChart Points="lineData" Threshold="400" Width="720" Height="240" />

<h2 style="margin-top:32px">Area chart</h2>
<p class="dx-demo-meta">A filled series, also Rust-downsampled.</p>
<DxAreaChart Points="areaData" Threshold="300" Width="720" Height="200" />

<h2 style="margin-top:32px">Bar chart (interactive)</h2>
<p class="dx-demo-meta">
    Wiring <code>OnPointSelected</code> turns the chart into a keyboard-navigable widget — click a
    bar, or Tab to it and use arrow keys + Enter/Space. Selected: <strong>@selectedBar</strong>.
</p>
<DxBarChart Points="bars" Width="720" Height="240" OnPointSelected="OnBarSelected" />

<h2 style="margin-top:32px">Bind an existing type — <code>[ChartRow]</code></h2>
<p class="dx-demo-meta">
    No manual mapping: annotate a domain type's properties with <code>[ChartValue(ChartField.…)]</code>
    once, and <code>rows.ToChartPoints()</code> — a <c>BlazorDX.SourceGen</c>-generated extension,
    zero reflection — projects it for any chart. See <code>SalesRecord</code> below.
</p>
<DxBarChart Points="salesPoints" Width="720" Height="220" />

<h2 style="margin-top:32px">Histogram (Rust binning)</h2>
<p class="dx-demo-meta">
    @sample.Length.ToString("N0") normally-distributed samples binned into 16 buckets
    by the compute backend — the caption names it.
</p>
<DxHistogram Values="sample" Bins="16" Width="720" Height="220" />

<h2 style="margin-top:32px">Pie &amp; donut (legend toggle)</h2>
<p class="dx-demo-meta">
    The legend is always click/keyboard-operable — toggle an entry to hide or restore that slice,
    redistributing the circle over what remains. Legend: <strong>@legendStatus</strong>.
</p>
<div style="display:flex; gap:32px; flex-wrap:wrap">
    <DxPieChart Points="slices" OnLegendToggled="OnPieLegendToggled" />
    <DxPieChart Points="slices" Donut="true" OnLegendToggled="OnPieLegendToggled" />
</div>

<h2 style="margin-top:32px">Sparklines</h2>
<table style="border-collapse:collapse">
    <tr>
        <td style="padding:6px 14px">Revenue</td>
        <td style="padding:6px 14px"><DxSparkline Points="spark" /></td>
        <td style="padding:6px 14px"><DxSparkline Points="spark" Variant="bar" /></td>
    </tr>
</table>

<h2 style="margin-top:32px">Scatter</h2>
<DxScatterChart Points="scatter" Width="720" Height="260" />

<h2 style="margin-top:32px">Stacked &amp; grouped bar</h2>
<div style="display:flex; gap:32px; flex-wrap:wrap">
    <div>
        <p class="dx-demo-meta">Stacked</p>
        <DxStackedBarChart Categories="quarters" Points="stackedPoints" Width="340" Height="240" />
    </div>
    <div>
        <p class="dx-demo-meta">Grouped</p>
        <DxStackedBarChart Categories="quarters" Points="stackedPoints" Stacked="false" Width="340" Height="240" />
    </div>
</div>

<h2 style="margin-top:32px">Gauges</h2>
<div style="display:flex; gap:40px; flex-wrap:wrap; align-items:center">
    <DxRadialGauge Value="72" Label="CPU %" />
    <DxRadialGauge Value="46" Max="60" Label="FPS" Color="#16a34a" Format="0" />
    <div style="display:flex; flex-direction:column; gap:14px">
        <DxLinearGauge Value="72" AriaLabel="Disk" Zones="zones" />
        <DxLinearGauge Value="28" AriaLabel="Memory" Zones="zones" />
        <DxLinearGauge Value="95" AriaLabel="Heat" Zones="zones" />
    </div>
</div>

<h2 style="margin-top:32px">Radar</h2>
<DxRadarChart Axes="radarAxes" Points="radarPoints" Width="340" Height="340" />

<h2 style="margin-top:32px">Funnel</h2>
<DxFunnelChart Points="funnelStages" Width="380" Height="240" />

<h2 style="margin-top:32px">Candlestick</h2>
<DxCandlestickChart Points="candles" Width="640" Height="260" />

<h2 style="margin-top:32px">Waterfall</h2>
<p class="dx-demo-meta">
    Bars float from a running total; a point with <code>Y2</code> set is an absolute total that
    resets the running total (the dashed connectors trace it across bars).
</p>
<DxWaterfallChart Points="waterfallPoints" Width="640" Height="260" Gradient="true" />

<h2 style="margin-top:32px">Bubble</h2>
<p class="dx-demo-meta">A scatter plot with a third dimension — <code>Y2</code> — encoded as radius.</p>
<DxBubbleChart Points="bubblePoints" Width="640" Height="300" />

<h2 style="margin-top:32px">Heatmap</h2>
<p class="dx-demo-meta">
    <code>Series</code> is the row, <code>Category</code> is the column, <code>Y</code> is the
    value — intensity is a fill-opacity scale on the chart's own accent color, so it stays
    theme-safe.
</p>
<DxHeatmap Points="heatmapPoints" Width="640" Height="220" ShowValues="true" />

<h2 style="margin-top:32px">Bullet</h2>
<p class="dx-demo-meta">A KPI vs. target vs. qualitative range bands — Stephen Few's bullet-graph design.</p>
<DxBulletChart Points="bulletPoints" Width="640" RowHeight="44" />

<h2 style="margin-top:32px">Treemap</h2>
<p class="dx-demo-meta">
    Nested rectangles sized by <code>ChartTreeNode.Value</code>, squarified so cells stay close to
    square. Click a cell: <strong>@treemapSelection</strong>.
</p>
<DxTreemap Root="treemapRoot" Width="640" Height="280" OnNodeSelected="OnTreemapNodeSelected" />

<h2 style="margin-top:32px">Sunburst</h2>
<p class="dx-demo-meta">The same <code>ChartTreeNode</code> tree — every node draws as its own ring, not just leaves.</p>
<DxSunburst Root="treemapRoot" Size="320" />

<h2 style="margin-top:32px">Box &amp; violin plot</h2>
<p class="dx-demo-meta">
    Q1/median/Q3 box, whiskers, and outliers beyond 1.5&times; IQR — with a density silhouette
    behind each box.
</p>
<DxBoxPlot Groups="boxPlotGroups" Width="640" Height="280" Violin="true" />

<h2 style="margin-top:32px">Sankey</h2>
<p class="dx-demo-meta">Flow between stages, ribbon thickness scaled to value.</p>
<DxSankeyChart Nodes="sankeyNodes" Links="sankeyLinks" Width="640" Height="280" />

@code {
    private readonly double[] points = new double[6000];
    private IReadOnlyList<ChartPoint> lineData = [];
    private IReadOnlyList<ChartPoint> areaData = [];
    private double[] sample = [];

    // No manual ChartPoint construction here — .ToChartPoints() is generated by BlazorDX.SourceGen
    // straight off the [ChartValue] attributes on SalesRecord.
    private readonly IReadOnlyList<ChartPoint> salesPoints = new List<SalesRecord>
    {
        new() { Quarter = "Q1", Revenue = 240, Region = "West" },
        new() { Quarter = "Q2", Revenue = 310, Region = "West" },
        new() { Quarter = "Q3", Revenue = 275, Region = "West" },
        new() { Quarter = "Q4", Revenue = 360, Region = "West" },
    }.ToChartPoints();

    private string selectedBar = "(none)";
    private string legendStatus = "(none)";

    private void OnBarSelected(ChartPointEventArgs e) =>
        selectedBar = $"{e.Point.Category} = {e.Point.Y:0.##}";

    private void OnPieLegendToggled(ChartLegendToggledEventArgs e) =>
        legendStatus = $"{e.Key} {(e.Visible ? "shown" : "hidden")}";

    private readonly IReadOnlyList<ChartPoint> bars =
    [
        new(Category: "Mon", Y: 18),
        new(Category: "Tue", Y: 32),
        new(Category: "Wed", Y: 27),
        new(Category: "Thu", Y: 41),
        new(Category: "Fri", Y: 36),
        new(Category: "Sat", Y: 12),
        new(Category: "Sun", Y: 9),
    ];

    private readonly IReadOnlyList<ChartPoint> spark =
    [
        new(Y: 4), new(Y: 7), new(Y: 5), new(Y: 9), new(Y: 6), new(Y: 11),
        new(Y: 8), new(Y: 13), new(Y: 10), new(Y: 15), new(Y: 12), new(Y: 17),
    ];

    private readonly IReadOnlyList<ChartPoint> scatter = BuildScatter();

    private static IReadOnlyList<ChartPoint> BuildScatter()
    {
        Random random = new(20260617);
        List<ChartPoint> pts = new(120);
        for (int i = 0; i < 120; i++)
        {
            double x = random.NextDouble() * 100;
            double y = (x * 0.6) + ((random.NextDouble() - 0.5) * 40);   // correlated with noise
            pts.Add(new ChartPoint(x, y));
        }

        return pts;
    }

    private readonly IReadOnlyList<string> quarters = ["Q1", "Q2", "Q3", "Q4"];

    // Flattened: one ChartPoint per (series, category) pair, tagged via Series + Category.
    private readonly IReadOnlyList<ChartPoint> stackedPoints =
    [
        new(Category: "Q1", Y: 18, Series: "Direct"), new(Category: "Q2", Y: 24, Series: "Direct"),
        new(Category: "Q3", Y: 30, Series: "Direct"), new(Category: "Q4", Y: 28, Series: "Direct"),
        new(Category: "Q1", Y: 12, Series: "Search"), new(Category: "Q2", Y: 16, Series: "Search"),
        new(Category: "Q3", Y: 14, Series: "Search"), new(Category: "Q4", Y: 22, Series: "Search"),
        new(Category: "Q1", Y: 8, Series: "Social"), new(Category: "Q2", Y: 6, Series: "Social"),
        new(Category: "Q3", Y: 11, Series: "Social"), new(Category: "Q4", Y: 9, Series: "Social"),
    ];

    private readonly IReadOnlyList<GaugeZone> zones =
    [
        new GaugeZone(50, "#16a34a"),
        new GaugeZone(80, "#d97706"),
        new GaugeZone(100, "#dc2626"),
    ];

    private readonly IReadOnlyList<string> radarAxes = ["Speed", "Power", "Range", "Agility", "Defense"];

    private readonly IReadOnlyList<ChartPoint> radarPoints =
    [
        new(Category: "Speed", Y: 80, Series: "Model A"), new(Category: "Power", Y: 55, Series: "Model A"),
        new(Category: "Range", Y: 70, Series: "Model A"), new(Category: "Agility", Y: 60, Series: "Model A"),
        new(Category: "Defense", Y: 90, Series: "Model A"),
        new(Category: "Speed", Y: 60, Series: "Model B"), new(Category: "Power", Y: 85, Series: "Model B"),
        new(Category: "Range", Y: 50, Series: "Model B"), new(Category: "Agility", Y: 75, Series: "Model B"),
        new(Category: "Defense", Y: 65, Series: "Model B"),
    ];

    private readonly IReadOnlyList<ChartPoint> funnelStages =
    [
        new(Category: "Visited", Y: 12000),
        new(Category: "Signed up", Y: 4800),
        new(Category: "Activated", Y: 2100),
        new(Category: "Purchased", Y: 720),
    ];

    private readonly IReadOnlyList<ChartPoint> candles =
    [
        new(Category: "Mon", Y: 100, Y2: 112, Y3: 96, Y4: 108),
        new(Category: "Tue", Y: 108, Y2: 114, Y3: 103, Y4: 105),
        new(Category: "Wed", Y: 105, Y2: 118, Y3: 104, Y4: 116),
        new(Category: "Thu", Y: 116, Y2: 120, Y3: 110, Y4: 112),
        new(Category: "Fri", Y: 112, Y2: 122, Y3: 108, Y4: 121),
    ];

    private readonly IReadOnlyList<ChartPoint> slices =
    [
        new(Category: "Direct", Y: 42),
        new(Category: "Search", Y: 28),
        new(Category: "Social", Y: 18),
        new(Category: "Email", Y: 12),
    ];

    private readonly IReadOnlyList<ChartPoint> waterfallPoints =
    [
        new(Category: "Starting cash", Y2: 120),
        new(Category: "Revenue", Y: 85),
        new(Category: "COGS", Y: -32),
        new(Category: "Opex", Y: -41),
        new(Category: "Other income", Y: 9),
        new(Category: "Ending cash", Y2: 141),
    ];

    private readonly IReadOnlyList<ChartPoint> bubblePoints = BuildBubbles();

    private static IReadOnlyList<ChartPoint> BuildBubbles()
    {
        Random random = new(20260716);
        List<ChartPoint> pts = new(24);
        for (int i = 0; i < 24; i++)
        {
            double x = random.NextDouble() * 100;
            double y = random.NextDouble() * 100;
            double size = 5 + (random.NextDouble() * 95);
            pts.Add(new ChartPoint(x, y, Category: $"Item {i + 1}", Y2: size));
        }

        return pts;
    }

    private readonly IReadOnlyList<ChartPoint> heatmapPoints = BuildHeatmap();

    private static IReadOnlyList<ChartPoint> BuildHeatmap()
    {
        string[] days = ["Mon", "Tue", "Wed", "Thu", "Fri"];
        string[] shifts = ["Morning", "Afternoon", "Evening"];
        Random random = new(20260716);
        List<ChartPoint> pts = new(days.Length * shifts.Length);
        foreach (string shift in shifts)
        {
            foreach (string day in days)
            {
                pts.Add(new ChartPoint(Category: day, Series: shift, Y: random.Next(2, 40)));
            }
        }

        return pts;
    }

    private readonly IReadOnlyList<BulletPoint> bulletPoints =
    [
        new("Revenue", Value: 84, Target: 90, Max: 100, Ranges: [40, 75]),
        new("New signups", Value: 62, Target: 50, Max: 100, Ranges: [30, 65]),
        new("Support CSAT", Value: 91, Target: 85, Max: 100, Ranges: [60, 85]),
    ];

    private string treemapSelection = "(none)";

    private readonly ChartTreeNode treemapRoot = new("Cloud spend", Children:
    [
        new("Compute", Children:
        [
            new("EC2", Value: 42), new("Lambda", Value: 11), new("Batch", Value: 6),
        ]),
        new("Storage", Children:
        [
            new("S3", Value: 28), new("EBS", Value: 9),
        ]),
        new("Data", Children:
        [
            new("RDS", Value: 18), new("Redshift", Value: 14), new("DynamoDB", Value: 7),
        ]),
        new("Networking", Value: 12),
    ]);

    private void OnTreemapNodeSelected(ChartTreeNodeEventArgs e) =>
        treemapSelection = $"{string.Join(" / ", e.Path)} ({e.Node.Value:0.##})";

    private readonly IReadOnlyList<BoxPlotGroup> boxPlotGroups =
    [
        new("Control", BuildSample(20260716, 50, 8)),
        new("Variant A", BuildSample(20260717, 58, 10)),
        new("Variant B", BuildSample(20260718, 47, 6)),
    ];

    private static IReadOnlyList<double> BuildSample(int seed, double mean, double stdDev)
    {
        Random random = new(seed);
        double[] values = new double[80];
        for (int i = 0; i < values.Length; i++)
        {
            // Sum of 6 uniforms -> approximately normal, same trick OnInitialized uses for the histogram.
            double s = 0;
            for (int k = 0; k < 6; k++)
            {
                s += random.NextDouble();
            }

            values[i] = mean + ((s / 6 - 0.5) * stdDev * 4);
        }

        return values;
    }

    private readonly IReadOnlyList<SankeyNode> sankeyNodes =
    [
        new("visited", "Visited"), new("signedup", "Signed up"), new("trial", "Started trial"),
        new("paid", "Paid"), new("churned", "Churned"),
    ];

    private readonly IReadOnlyList<SankeyLink> sankeyLinks =
    [
        new("visited", "signedup", 1000),
        new("signedup", "trial", 620),
        new("trial", "paid", 240),
        new("trial", "churned", 380),
    ];

    protected override void OnInitialized()
    {
        // A noisy multi-frequency wave: lots of detail LTTB must preserve.
        Random random = new(20260617);
        ChartPoint[] line = new ChartPoint[points.Length];
        for (int i = 0; i < points.Length; i++)
        {
            double wave = (Math.Sin(i / 120.0) * 80) + (Math.Sin(i / 17.0) * 18);
            double y = wave + ((random.NextDouble() - 0.5) * 24);
            line[i] = new ChartPoint(X: i, Y: y);
        }

        lineData = line;

        // Area: a smoother positive series.
        ChartPoint[] area = new ChartPoint[1500];
        for (int i = 0; i < area.Length; i++)
        {
            area[i] = new ChartPoint(Y: 50 + (Math.Sin(i / 90.0) * 30) + (Math.Sin(i / 23.0) * 10));
        }

        areaData = area;

        // Histogram: 20k normal-ish samples (sum of uniforms → bell curve).
        sample = new double[20000];
        for (int i = 0; i < sample.Length; i++)
        {
            double s = 0;
            for (int k = 0; k < 6; k++)
            {
                s += random.NextDouble();
            }

            sample[i] = s / 6 * 100;   // centered near 50
        }
    }
}
