@page "/richtext"
@rendermode InteractiveWebAssembly
@using System.Text.RegularExpressions
@using BlazorDX.Components
@using BlazorDX.Security

<PageTitle>Rich Text</PageTitle>

<h1>BlazorDX Rich Text Editor</h1>

<p class="dx-demo-meta">
    A WYSIWYG editor. Edited HTML is read from the DOM and routed through an
    <strong>injected sanitizer</strong> before it becomes the bound value — BlazorDX
    ships no HTML parser, so the app supplies its policy. The allow-list below is a
    <em>demo-grade</em> regex policy (real apps use a vetted library); paste a
    <code>&lt;script&gt;</code> or an <code>onerror</code> attribute and watch it
    vanish from the stored value.
</p>

<DxRichTextEditor @bind-Value="html" Sanitizer="sanitizer" AriaLabel="Document body" />

<h2 style="margin-top:24px">Stored (sanitized) value</h2>
<pre class="dx-demo-code">@html</pre>

@code {
    private string? html = "<h2>Welcome</h2><p>Edit me — try <b>bold</b> and a <i>list</i>.</p>";

    // Demo-grade allow-list sanitizer. Illustrative only: production apps should
    // inject a vetted library (e.g. Ganss.Xss). It strips script/style blocks,
    // event-handler attributes, javascript: URLs, and any non-allow-listed tag.
    private readonly HtmlSanitizer sanitizer = new(Clean);

    private static readonly HashSet<string> Allowed =
        new(StringComparer.OrdinalIgnoreCase)
        { "b", "strong", "i", "em", "u", "h2", "h3", "ul", "ol", "li", "p", "br", "a", "div", "span" };

    private static string Clean(string input)
    {
        string html = Regex.Replace(input, "(?is)<(script|style)\\b.*?</\\1>", string.Empty);
        html = Regex.Replace(html, "(?i)\\son\\w+\\s*=\\s*\"[^\"]*\"", string.Empty);
        html = Regex.Replace(html, "(?i)\\son\\w+\\s*=\\s*'[^']*'", string.Empty);
        html = Regex.Replace(html, "(?i)(href|src)\\s*=\\s*([\"'])\\s*javascript:[^\"']*\\2", "$1=$2#$2");
        html = Regex.Replace(html, "(?i)</?([a-z0-9]+)[^>]*>",
            m => Allowed.Contains(m.Groups[1].Value) ? m.Value : string.Empty);
        return html;
    }
}
