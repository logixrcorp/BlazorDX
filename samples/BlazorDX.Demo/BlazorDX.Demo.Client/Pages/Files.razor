@page "/files"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components
@using BlazorDX.Primitives.Files
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>File Manager</PageTitle>

<h1>BlazorDX File Manager</h1>

<p class="dx-demo-meta">
    A two-pane file manager: a folder tree on the left, the selected folder's
    contents on the right. Click a folder to select it (ancestors auto-expand);
    double-click a folder to drill in, or a file to open it. Opened:
    <strong>@opened</strong>.
</p>

<p class="dx-demo-meta">
    <strong>Hybrid drag-and-drop.</strong> Drag a row onto a folder (in either pane)
    to move it, or drop OS files onto the contents pane to upload. Every gesture has a
    non-drag equivalent: the ↔ button on a row arms a keyboard/single-pointer move
    (then pick a destination's <em>Move here</em>), and <em>Upload files</em> is the
    always-available upload path. Last action: <strong>@status</strong>.
</p>

<p class="dx-demo-meta">
    <strong>Upload integrity (two-sided SHA-256).</strong> With <code>VerifyIntegrity</code>
    on, each uploaded file is hashed in the browser with Web Crypto, then re-hashed here from
    the received stream and compared — so corruption in transit is caught before anything is
    written. Pick a file with <em>Upload files</em> to see its result:
</p>

@if (integrity.Count > 0)
{
    <ul class="dx-demo-meta">
        @foreach (FileIntegrityResult r in integrity)
        {
            <li>
                <strong>@r.Name</strong> (@r.Size B):
                @if (r.Verified)
                {
                    <span>✓ verified — SHA-256 <code>@Short(r.ServerHash)</code></span>
                }
                else
                {
                    <span>✗ not verified (client <code>@Short(r.ClientHash)</code> vs server <code>@Short(r.ServerHash)</code>)</span>
                }
            </li>
        }
    </ul>
}

<DxFileManager Roots="roots"
               VerifyIntegrity="true"
               OnFileOpen="OnOpen"
               OnItemMove="OnMove"
               OnUpload="OnUpload"
               OnUploadVerified="OnVerified"
               OnFilesDropped="OnDropped" />

@code {
    private string opened = "(none)";
    private string status = "(none)";

    private void OnOpen(FileSystemEntry file) => opened = file.Name;

    private void OnMove(MoveResult result) =>
        status = result.Succeeded
            ? $"moved {result.Item.Name} to {result.Target?.Name ?? "Files"}"
            : $"move of {result.Item.Name} rejected";

    private IReadOnlyList<FileIntegrityResult> integrity = [];

    private void OnUpload(IReadOnlyList<IBrowserFile> files) =>
        status = $"selected {files.Count} file(s) to upload";

    private void OnVerified(IReadOnlyList<FileIntegrityResult> results)
    {
        integrity = results;
        int ok = results.Count(r => r.Verified);
        status = $"verified {ok}/{results.Count} upload(s)";
    }

    private static string Short(string hash) =>
        string.IsNullOrEmpty(hash) ? "—" : (hash.Length <= 16 ? hash : hash[..16] + "…");

    private void OnDropped(FileDropArgs args) =>
        status = $"dropped {args.Files.Count} file(s) onto {args.Destination?.Name ?? "Files"}";

    private static readonly DateOnly Day = new(2026, 6, 1);

    private readonly IReadOnlyList<FileSystemEntry> roots =
    [
        new FileSystemEntry
        {
            Name = "src", IsDirectory = true, Modified = Day,
            Children =
            [
                new FileSystemEntry
                {
                    Name = "BlazorDX.Primitives", IsDirectory = true, Modified = Day,
                    Children =
                    [
                        new() { Name = "DataGridPrimitive.cs", Size = 28_400, Modified = Day },
                        new() { Name = "TreeGridPrimitive.cs", Size = 6_100, Modified = Day },
                        new() { Name = "FileManagerPrimitive.cs", Size = 5_200, Modified = Day },
                    ],
                },
                new FileSystemEntry
                {
                    Name = "BlazorDX.Components", IsDirectory = true, Modified = Day,
                    Children =
                    [
                        new() { Name = "DxFileManager.cs", Size = 7_800, Modified = Day },
                        new() { Name = "DxScheduler.cs", Size = 6_400, Modified = Day },
                    ],
                },
            ],
        },
        new FileSystemEntry
        {
            Name = "docs", IsDirectory = true, Modified = Day,
            Children =
            [
                new() { Name = "ARCHITECTURE.md", Size = 9_200, Modified = Day },
                new() { Name = "ROADMAP.md", Size = 5_000, Modified = Day },
            ],
        },
        new() { Name = "README.md", Size = 7_100, Modified = Day },
    ];
}
