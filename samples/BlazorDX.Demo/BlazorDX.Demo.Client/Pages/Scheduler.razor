@page "/scheduler"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components
@using BlazorDX.Primitives.Scheduling

<PageTitle>Scheduler</PageTitle>

<h1>BlazorDX Scheduler</h1>

<p class="dx-demo-meta">
    A week view. Events are laid out by start/end time within their day column,
    clamped to the visible hours. Use ‹ / › to change week, Today to return.
    Last selected: <strong>@lastSelected</strong>.
</p>

<DxScheduler Events="events"
             @bind-WeekStart="weekStart"
             StartHour="8"
             EndHour="18"
             OnEventSelected="OnSelected" />

@code {
    private DateOnly weekStart = MondayOf(DateOnly.FromDateTime(DateTime.Today));
    private string lastSelected = "(none)";

    private void OnSelected(SchedulerEvent ev) => lastSelected = ev.Title;

    private static DateOnly MondayOf(DateOnly date) =>
        date.AddDays(-((int)date.DayOfWeek + 6) % 7);

    private IReadOnlyList<SchedulerEvent> events => BuildEvents(weekStart);

    private static IReadOnlyList<SchedulerEvent> BuildEvents(DateOnly week)
    {
        DateTime monday = week.ToDateTime(TimeOnly.MinValue);
        return
        [
            new SchedulerEvent("Standup", monday.AddHours(9), monday.AddHours(9.5)),
            new SchedulerEvent("Design review", monday.AddDays(1).AddHours(11), monday.AddDays(1).AddHours(12.5), "#16a34a"),
            new SchedulerEvent("1:1", monday.AddDays(2).AddHours(14), monday.AddDays(2).AddHours(15)),
            new SchedulerEvent("Release", monday.AddDays(3).AddHours(10), monday.AddDays(3).AddHours(13), "#d97706"),
            new SchedulerEvent("Retro", monday.AddDays(4).AddHours(16), monday.AddDays(4).AddHours(17), "#7c3aed"),
        ];
    }
}
