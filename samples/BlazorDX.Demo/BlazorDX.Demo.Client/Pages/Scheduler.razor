@page "/scheduler"
@rendermode InteractiveWebAssembly
@using BlazorDX.Components
@using BlazorDX.Primitives.Scheduling

<PageTitle>Scheduler</PageTitle>

<h1>BlazorDX Scheduler</h1>

<p class="dx-demo-meta">
    Week, Month, and Day views. Switch with the Week / Month / Day control (it is
    keyboard-accessible — arrow keys move between views). Inside a view, the grid
    takes focus and arrow keys move a roving active cell (Home/End jump to the row
    edges, Ctrl+Home/End to the corners; PageUp/PageDown move by a week in Month
    view or to the first/last hour in a time view). Events are buttons whose names include
    the date, time, title, and category; the category is shown as text, never colour
    alone. Use ‹ / › to change period, Today to return.
</p>

<p class="dx-demo-meta">
    <strong>Drag editing (time views).</strong> Drag an event block to move it to another
    day or time; drag across empty grid to create a new event. The pointer snaps to the
    half-hour and the grid auto-scrolls near its edges. Dragging is a progressive
    enhancement — keyboard navigation and click-to-select work without it. The recurring
    standup is generated from a repeat rule, so its occurrences aren't individually
    draggable. Last action: <strong>@lastAction</strong>.
</p>

<DxScheduler Events="events"
             @bind-WeekStart="weekStart"
             @bind-View="view"
             StartHour="8"
             EndHour="18"
             OnEventSelected="OnSelected"
             OnEventMoved="OnMoved"
             OnRangeCreated="OnCreated" />

@code {
    private DateOnly weekStart = MondayOf(DateOnly.FromDateTime(DateTime.Today));
    private SchedulerView view = SchedulerView.Week;
    private string lastAction = "(none)";
    private int created;

    private List<SchedulerEvent> events = new();

    protected override void OnInitialized() => events = BuildEvents(weekStart);

    private void OnSelected(SchedulerEvent ev) => lastAction = $"Selected \"{ev.Title}\"";

    private void OnMoved(SchedulerEventMove move)
    {
        // The Original is the exact value from the list, so value equality locates it.
        int i = events.IndexOf(move.Original);
        if (i >= 0)
        {
            events[i] = move.Original with { Start = move.NewStart, End = move.NewEnd };
            lastAction = $"Moved \"{move.Original.Title}\" to {move.NewStart:ddd HH:mm}";
        }
    }

    private void OnCreated(SchedulerRange range)
    {
        created++;
        events.Add(new SchedulerEvent($"New event {created}", range.Start, range.End, Category: "New"));
        lastAction = $"Created event {created} at {range.Start:ddd HH:mm}–{range.End:HH:mm}";
    }

    private static DateOnly MondayOf(DateOnly date) =>
        date.AddDays(-((int)date.DayOfWeek + 6) % 7);

    private static List<SchedulerEvent> BuildEvents(DateOnly week)
    {
        DateTime monday = week.ToDateTime(TimeOnly.MinValue);
        return
        [
            // A weekly recurring standup on Mon/Wed/Fri — expanded by the engine, so it shows
            // in every week you navigate to (its occurrences are generated, not draggable).
            new SchedulerEvent("Standup", monday.AddHours(9), monday.AddHours(9.5), Category: "Meeting",
                Recurrence: new Recurrence(
                    RecurrenceFrequency.Weekly,
                    ByWeekday: [DayOfWeek.Monday, DayOfWeek.Wednesday, DayOfWeek.Friday])),
            // One-off events (drag these to move them).
            new SchedulerEvent("Design review", monday.AddDays(1).AddHours(11), monday.AddDays(1).AddHours(12.5), "#16a34a", "Confirmed"),
            new SchedulerEvent("1:1", monday.AddDays(2).AddHours(14), monday.AddDays(2).AddHours(15), Category: "Meeting"),
            new SchedulerEvent("Release", monday.AddDays(3).AddHours(10), monday.AddDays(3).AddHours(13), "#d97706", "Tentative"),
            new SchedulerEvent("Retro", monday.AddDays(4).AddHours(16), monday.AddDays(4).AddHours(17), "#7c3aed", "Confirmed"),
            // Multi-day span (shows in every Month cell it touches; Tue–Thu).
            new SchedulerEvent("Offsite", monday.AddDays(1).AddHours(9), monday.AddDays(3).AddHours(17), "#0891b2", "Travel"),
            // Crosses midnight (renders a block on both the Wed and Thu columns).
            new SchedulerEvent("On-call", monday.AddDays(2).AddHours(22), monday.AddDays(3).AddHours(2), "#be123c", "Coverage"),
        ];
    }
}
