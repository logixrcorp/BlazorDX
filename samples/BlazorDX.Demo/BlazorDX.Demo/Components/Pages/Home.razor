@page "/"
@using BlazorDX.Components
@using BlazorDX.Demo.Components

<PageTitle>BlazorDX — headless, AOT-safe Blazor components</PageTitle>

<section class="dx-hero">
    <div class="dx-hero-inner">
        <h1>Blazor<span class="dx-accent">DX</span></h1>
        <p class="dx-hero-tagline">
            A secure-by-default, <strong>headless</strong>, AOT-safe Blazor component
            system for .NET&nbsp;10 — C# for the render tree, Rust for heavy compute,
            TypeScript for the DOM bridge. Restyle anything through CSS variables.
        </p>

        <div class="dx-stats">
            <span class="dx-stat"><strong>90+</strong> components</span>
            <span class="dx-stat"><strong>386</strong> tests green</span>
            <span class="dx-stat"><strong>0</strong> reflection · trim-clean</span>
            <span class="dx-stat"><strong>Source-available</strong> license</span>
            <span class="dx-stat"><strong>1000-line</strong> file cap, enforced</span>
        </div>

        <div class="dx-hero-actions">
            <a class="dx-btn-primary" href="#getting-started">Get started</a>
            <a class="dx-btn-ghost" href="#catalog">Browse components</a>
            <a class="dx-btn-ghost" href="/grid">Live DataGrid (100k rows)</a>
        </div>

        @* These previews are real components rendered during static SSR — pure SVG,
           no JavaScript and no DI, so they paint instantly on first load. *@
        <div class="dx-hero-preview">
            <div class="dx-preview-card">
                <span class="dx-preview-label">QR</span>
                <DxQrCode Value="https://github.com" ModuleSize="4" />
            </div>
            <div class="dx-preview-card">
                <span class="dx-preview-label">Bar chart</span>
                <DxBarChart Bars="heroBars" Width="180" Height="92" />
            </div>
            <div class="dx-preview-card">
                <span class="dx-preview-label">Radial gauge</span>
                <DxRadialGauge Value="72" Size="104" Label="CPU %" />
            </div>
            <div class="dx-preview-card">
                <span class="dx-preview-label">Sparkline</span>
                <DxSparkline Values="heroSpark" Width="150" Height="46" />
                <DxRating Value="4" ReadOnly="true" />
            </div>
        </div>
    </div>
</section>

<section class="dx-section">
    <h2>Why BlazorDX</h2>
    <p class="dx-section-sub">Built to beat the incumbents on the dimensions they skip.</p>
    <div class="dx-pillars">
        <div class="dx-pillar">
            <div class="dx-pillar-icon">🛡️</div>
            <h3>Zero reflection, AOT-safe</h3>
            <p>Grid binding is source-generated; JSON via contexts; interop via
               <code>[JSImport]</code>. The whole catalog publishes trim-clean with
               warnings-as-errors.</p>
        </div>
        <div class="dx-pillar">
            <div class="dx-pillar-icon">🎨</div>
            <h3>Headless, two-tier</h3>
            <p>A Tier-1 primitive owns behavior, focus, and WAI-ARIA with no CSS.
               A Tier-2 <code>Dx*</code> wrapper styles it through CSS variables —
               no <code>!important</code> fights.</p>
        </div>
        <div class="dx-pillar">
            <div class="dx-pillar-icon">⚙️</div>
            <h3>C# · Rust · TypeScript</h3>
            <p>Sort, filter, aggregate, histogram and downsample run in a Rust→wasm
               kernel (with a managed fallback for SSR). TypeScript handles only what
               the sandbox can't.</p>
        </div>
        <div class="dx-pillar">
            <div class="dx-pillar-icon">📏</div>
            <h3>Governed by tooling</h3>
            <p>A hard 1000-line file cap, a <code>MarkupString</code> ban, and a
               singleton-UI-state ban are Roslyn analyzers that fail the build — not
               style guidelines.</p>
        </div>
    </div>
</section>

<section class="dx-section" id="getting-started">
    <h2>Getting started</h2>
    <p class="dx-section-sub">Three steps from empty project to a Rust-backed grid.</p>
    <div class="dx-steps">
        <div class="dx-step">
            <div class="dx-step-num">1</div>
            <div class="dx-step-body">
                <h3>Add the packages</h3>
                <p>Pull in the styled components plus the source generator and analyzers.</p>
                <CodeBlock Language="bash" Code="@InstallCode" />
            </div>
        </div>
        <div class="dx-step">
            <div class="dx-step-num">2</div>
            <div class="dx-step-body">
                <h3>Register services &amp; styles</h3>
                <p>Wire the interop bridge (browser real / SSR null) in <code>Program.cs</code>
                   and link the component CSS. Register shared services in <em>both</em>
                   the server and client projects — WASM pages prerender on the server too.</p>
                <CodeBlock Language="csharp" Code="@RegisterCode" />
            </div>
        </div>
        <div class="dx-step">
            <div class="dx-step-num">3</div>
            <div class="dx-step-body">
                <h3>Drop in a component</h3>
                <p>Mark your row type with <code>[GridRow]</code> and the generator emits a
                   reflection-free accessor. No <code>PropertyInfo</code>, ever.</p>
                <CodeBlock Language="razor" Code="@UsageCode" />
            </div>
        </div>
    </div>
</section>

<section class="dx-section" id="catalog">
    <h2>Component catalog</h2>
    <p class="dx-section-sub">
        Every component below ships a live demo and a copy-pasteable example. Click
        <strong>Show code</strong> on any card, or follow <strong>Demo →</strong> to try it.
    </p>

    @foreach (Category category in Catalog)
    {
        <h3 style="font-size:17px; margin:28px 0 4px">@category.Title</h3>
        <p class="dx-demo-meta" style="margin:0 0 14px">@category.Blurb</p>
        <div class="dx-cat-grid">
            @foreach (Comp comp in category.Items)
            {
                <div class="dx-comp-card">
                    <div class="dx-comp-head">
                        <span class="dx-comp-name">@comp.Name</span>
                        <a class="dx-comp-demo" href="@comp.Href">Demo →</a>
                    </div>
                    <p class="dx-comp-summary">@comp.Summary</p>
                    <details>
                        <summary>Show code</summary>
                        <CodeBlock Language="razor" Code="@comp.Code" />
                    </details>
                </div>
            }
        </div>
    }
</section>

