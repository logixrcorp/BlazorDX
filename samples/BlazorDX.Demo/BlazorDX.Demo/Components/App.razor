</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Copy-to-clipboard for showcase code blocks. Delegated so it survives
        // Blazor enhanced navigation without re-wiring.
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.dx-copy');
            if (!btn) return;
            var code = btn.closest('.dx-code')?.querySelector('code')?.textContent ?? '';
            navigator.clipboard?.writeText(code).then(function () {
                var original = btn.textContent;
                btn.textContent = 'Copied!';
                btn.classList.add('dx-copied');
                setTimeout(function () { btn.textContent = original; btn.classList.remove('dx-copied'); }, 1200);
            });
        });
    </script>
</body>

</html>
