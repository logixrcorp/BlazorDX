    @* A stub window.powerbi loaded before Blazor, so dx-powerbi.js uses it instead of
       fetching the real SDK from the CDN (no tenant needed); it records the embed config
       on window.__lastEmbed for the E2E. Skipped when PlaygroundSample is on (Production),
       where the wrapper loads the real powerbi-client SDK and embeds the live sample. *@
    @if (!Configuration.GetValue<bool>("PowerBI:PlaygroundSample"))
    {
        <script src="powerbi-stub.js"></script>
    }
    <script src="https://unpkg.com/htmx.org@2.0.3" integrity="sha384-0895/pl2MU10Hqc6jd4RvrthNlDiE9U1tWmX7WRESftEDRosgxNsQG/Ze9YMRzHq" crossorigin="anonymous"></script>
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Copy-to-clipboard for showcase code blocks. Delegated so it survives
        // Blazor enhanced navigation without re-wiring.
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.dx-copy');
            if (!btn) return;
            var code = btn.closest('.dx-code')?.querySelector('code')?.textContent ?? '';
            navigator.clipboard?.writeText(code).then(function () {
                var original = btn.textContent;
                btn.textContent = 'Copied!';
                btn.classList.add('dx-copied');
                setTimeout(function () { btn.textContent = original; btn.classList.remove('dx-copied'); }, 1200);
            });
        });
    </script>
</body>

</html>

@code {
    // Canonical / og:url for the current request, without query string or fragment.
    // Behind the Cloudflare tunnel, forwarded headers make this the public https URL.
    private string CanonicalUrl => new Uri(Nav.Uri).GetLeftPart(UriPartial.Path);
}
