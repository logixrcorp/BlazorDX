# Copy this file to `.env` (same folder) and fill in the real value. `.env` is gitignored.
#
# The Cloudflare tunnel token, from the Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared → copy the token shown in the
#   `cloudflared … run <TOKEN>` install command. It's a long opaque string.
TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here
